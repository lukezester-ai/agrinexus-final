# ─── OpenAI (чат) ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.35

# ─── Локален API ───
DEV_API_PORT=8788

# Лог на запитвания в .local/leads.jsonl (0 / 1)
AGRI_STORE_LEADS=0

# ─── Имейли: Resend ИЛИ SMTP (ако и двете липсват → контакт/регистрация без имейл, само JSONL при AGRI_STORE_LEADS=1)
# Примерни получатели:
MAIL_TO=info@agrinexus.eu
# Или:
# CONTACT_TO_EMAIL=info@agrinexus.eu

# Resend: https://resend.com — верифицирай домейна за "from"
RESEND_API_KEY=
MAIL_FROM=AgriNexus <noreply@твой-домейн.com>

# SMTP алтернатива (ако няма RESEND_API_KEY):
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=AgriNexus <noreply@example.com>

# ─── S3 / Cloudflare R2 (presigned качване) ───
# R2: S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=auto
# Публичен URL на bucket/custom domain (по избор)
S3_PUBLIC_BASE_URL=

# Макс. размер на файл (байтове), подпис TTL
UPLOAD_MAX_BYTES=15728640
UPLOAD_SIGN_TTL_SEC=3600
