# ═══ ФАЙЛ: .env.example (шаблон за Git; БЕЗ истински секрети) ═══
# Копирай като `.env` в същата папка и попълни стойностите там.
# Приложението чете само `.env`, не `.env.example`.

# ─── LLM за чат: Mistral (EU облак) ИЛИ OpenAI ИЛИ локален Ollama ───
# Приоритет ако са зададени няколко: Mistral → Ollama → OpenAI.
# Ключ: https://console.mistral.ai — OpenAI-съвместим /v1/chat/completions
#MISTRAL_API_KEY=
#MISTRAL_MODEL=mistral-small-latest
# След fine-tuning в Mistral (console.mistral.ai → Fine-tuning) сложете id на обучения модел.
# Може един общ като MISTRAL_MODEL, или разделено:
#MISTRAL_CHAT_MODEL=
#MISTRAL_MARKET_INSIGHTS_MODEL=
# Dataset: JSONL с ключ "messages" ([{role, content}, …]); виж scripts/mistral-ft-chat.example.jsonl и https://docs.mistral.ai/capabilities/finetuning/
# За „Обясни документ“ със снимка (Pixtral / vision):
#MISTRAL_VISION_MODEL=pixtral-12b-2409

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.35

# Локален Ollama: инсталирай ollama.com → терминал: ollama serve → ollama pull llama3.2
#OLLAMA_BASE_URL=http://127.0.0.1:11434
#OLLAMA_MODEL=llama3.2
# За „Обясни документ“ със снимка нужен vision модел в Ollama:
#OLLAMA_VISION_MODEL=llava

# ─── Локален API (npm run dev — dev-server) ───
# От корена задължително: npm run dev (не само dev:vite) — Vite :5173 проксира /api към този порт.
# В браузър: http://localhost:5173 . Порт зает? Спри другата програма или смени DEV_API_PORT и имай предвид vite proxy към същия порт.
DEV_API_PORT=8788

# Пазарни котировки: не задавай | stooq (забавени фючърси) | demo (само синтетика, без външен HTTP)
MARKET_QUOTES_PROVIDER=stooq

# Проследяване на пазара в Supabase (таблица market_watch_state — supabase-market-watch.sql).
# 1 = при живи котировки записва статистика + опционално LLM клъстери и предположения (BG).
#MARKET_WATCH_PERSIST=1
# Мин. интервал между snapshot-и (ms); по подразбиране ~15 мин.
#MARKET_WATCH_SNAPSHOT_MIN_MS=
# 1 = периодично обобщение/предположения от LLM (нужен конфигуриран чат LLM).
#MARKET_WATCH_LLM_INSIGHTS=1
#MARKET_WATCH_LLM_EVERY_N_SNAPSHOTS=2
#MARKET_WATCH_LLM_TEMPERATURE=0.28
#MARKET_WATCH_LLM_MAX_TOKENS=900
# 1 = append-only редове в market_watch_ft_rows за експорт към Mistral FT (SQL: supabase-market-watch-ft-rows.sql).
#MARKET_WATCH_FT_LOG=1
# Експорт: npm run export:ft:market-watch -- --out=.local/market-watch-ft.jsonl
# Или един ред от текущия singleton: npm run export:ft:market-watch -- --from-singleton

# Frontend: 1 = не вика /api/market-quotes (офлайн, синтетика)
# VITE_SKIP_MARKET_QUOTES=1

# 1 = само основни екрани; скрива част от навигацията
# VITE_MVP_MODE=1

# Публичен URL на сайта (PDF/отчети/абсолютни линкове). Локално: http://localhost:5173
VITE_SITE_URL=http://localhost:5173

# Лог на лийдове в .local/leads.jsonl
AGRI_STORE_LEADS=0

# ─── Имейли: Resend ИЛИ SMTP (ако липсват → контакт без изходящ имейл) ───
MAIL_TO=info@agrinexus.eu
# CONTACT_TO_EMAIL=info@agrinexus.eu
# AGRI_INBOX_EMAIL=info@agrinexus.eu

RESEND_API_KEY=
# От: верифициран домейн в Resend
MAIL_FROM=
# RESEND_FROM=  (алтернативно име на поле From)

# SMTP алтернатива:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# MAIL_FROM=AgriNexus <noreply@example.com>

# ─── S3 / Cloudflare R2 (presigned качване) ───
# R2: S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=auto
S3_PUBLIC_BASE_URL=

UPLOAD_MAX_BYTES=15728640
UPLOAD_SIGN_TTL_SEC=3600
# Продукция (Vercel или NODE_ENV=production): /api/upload-sign изисква Bearer Supabase access_token (логнат потребител) ИЛИ UPLOAD_SIGN_SECRET (скриптове).
# Локален npm run dev: без това анонимните заявки към upload-sign са позволени за по-лесни тестове.
#UPLOAD_SIGN_SECRET=
# Внимание: отключва анонимни presigned URL-и в продукция — само при нужда.
#UPLOAD_SIGN_ALLOW_ANONYMOUS=1

# ─── Supabase (облак + Auth) ───
# Публични — влизат във Vite билда:
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Сървър (локален API / Vercel) — същият проект:
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Статистика за посещения (по избор; локално обикновено празно) ───
# Локален файл вместо Redis:
# VISIT_STATS_FILE=.local/visit-stats.json
# Upstash Redis (ако ползваш):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# VISIT_STATS_SECRET=  (за защита на write endpoint)

# След промяна на Supabase: рестарт на `npm run dev` или Redeploy.
# Magic link: Supabase → Auth → URL configuration → Site URL + Redirect URLs (localhost + продукция).

# ─── Нощен обход на публични документи (cron) ───
# Ръчни тестове (curl): Bearer токенът трябва да съвпада с DOC_DISCOVERY_CRON_SECRET.
DOC_DISCOVERY_CRON_SECRET=
# На Vercel: при зададен CRON_SECRET платформата праща Bearer към cron маршрутите — може да ползваш само него (без DOC_DISCOVERY_*).
#CRON_SECRET=
# Опционално отделен secret само за field learning cron; ако липсва се ползва CRON_SECRET.
#FIELD_LEARNING_CRON_SECRET=
# Опционално: подсказка в JSON отговора — зададеното число трябва да съвпада с часа UTC в vercel.json → crons.
#DOC_DISCOVERY_CRON_HOUR_UTC=2
#DOC_DISCOVERY_MAX_LINKS_PER_PAGE=24
#DOC_DISCOVERY_FETCH_TIMEOUT_MS=14000
#DOC_DISCOVERY_MAX_LEARNED_KEYWORDS_PER_TOPIC=48
# Авто-пауза на нестабилни индекси (cooldown в часове)
#DOC_DISCOVERY_FETCH_FAIL_STREAK=2
#DOC_DISCOVERY_FETCH_FAIL_COOLDOWN_HOURS=24
#DOC_DISCOVERY_ZERO_YIELD_STREAK=3
#DOC_DISCOVERY_ZERO_YIELD_COOLDOWN_HOURS=48
# По-умно учене: тежести на ключови думи + вторичен обход на HTML страници от същия сайт
#DOC_DISCOVERY_SECONDARY_PAGES_MAX=3
#DOC_DISCOVERY_WEIGHT_DECAY_FACTOR=0.988
#DOC_DISCOVERY_WEIGHT_FLOOR=0.35
#DOC_DISCOVERY_WEIGHT_BUMP=0.45
#DOC_DISCOVERY_MAX_WEIGHT_KEYS_PER_TOPIC=96
#DOC_DISCOVERY_LEARNING_PREVIEW_LIMIT=8
# Семантично ML търсене (embeddings → Supabase pgvector). По подразбиране Mistral при MISTRAL_API_KEY, иначе OpenAI.
# Избери ЕДИН SQL файл: supabase-doc-discovery-vectors-mistral.sql (1024) ИЛИ supabase-doc-discovery-vectors.sql (1536).
#DOC_DISCOVERY_EMBEDDINGS=auto
#DOC_DISCOVERY_VECTOR_DIM=
#DOC_DISCOVERY_ML_INDEX=1
#DOC_DISCOVERY_ML_MAX_DOCS_PER_RUN=30
#MISTRAL_EMBEDDING_MODEL=mistral-embed
#OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Семантично търсене GET /api/doc-discovery-search: в продукция задължителен; Bearer трябва да съвпада със секрета.
#DOC_DISCOVERY_SEARCH_SECRET=
# DL rerank (cross-encoder style през chat LLM) върху top semantic results
#DOC_DISCOVERY_DL_RERANK=1
# LLM предлага нови начални източници (HTTPS) за следващи обходи; ограничи общия брой и на рън.
#DOC_DISCOVERY_LLM_SOURCES=1
#DOC_DISCOVERY_MAX_DYNAMIC_SOURCES=28
#DOC_DISCOVERY_LLM_MAX_SOURCES_PER_RUN=5
#DOC_DISCOVERY_LLM_SOURCES_TEMPERATURE=0.2
#DOC_DISCOVERY_LLM_SOURCES_MAX_TOKENS=700
# Обобщение + предположения на база агрегирана статистика от нощните обходи (BG текст в payload).
#DOC_DISCOVERY_LLM_STATS_INSIGHTS=1
#DOC_DISCOVERY_LLM_INSIGHTS_TEMPERATURE=0.35
#DOC_DISCOVERY_LLM_INSIGHTS_MAX_TOKENS=900
# Нощен обход → LLM: след евристиката добавя нови ключови думи по теми и записва в Supabase state (Mistral → Ollama → OpenAI).
#DOC_DISCOVERY_LLM_LEARN=1
#DOC_DISCOVERY_LLM_MAX_KEYWORDS_PER_TOPIC=12
#DOC_DISCOVERY_LLM_KEYWORD_BOOT=1.22
#DOC_DISCOVERY_LLM_TEMPERATURE=0.25
#DOC_DISCOVERY_LLM_MAX_TOKENS=900
# Чат → LLM: допълване на system prompt с топ линкове от семантично търсене (RAG). По подразбиране включено при налични embeddings ключ + pgvector.
#CHAT_DOC_DISCOVERY_RAG=1
# SQL таблица: изпълни supabase-doc-discovery.sql в Supabase за да се запазват „научените“ ключови думи между пусканията.

# ─── Field Watch Learning Loop ───
# 1) Изпълни supabase-field-watch.sql (с learning table) в Supabase SQL Editor.
# 2) Пусни ръчно cron-а:
#    curl -H "Authorization: Bearer $FIELD_LEARNING_CRON_SECRET" https://<app>/api/field-learning-cron
# 3) Експорт за дообучение:
#    npm run export:ft:field-watch

