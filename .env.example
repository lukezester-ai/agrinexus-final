# ─── OpenAI (чат) ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.35

# ─── Локален API ───
DEV_API_PORT=8788

# Пазарни котировки: не задавай или задай stooq за забавени фючърси чрез Stooq (без ключ).
# demo — само синтетичен каталог без HTTP към външен поток.
MARKET_QUOTES_PROVIDER=stooq

# Локално frontend: 1 = не вика /api/market-quotes (офлайн работа по синтетика).
# VITE_SKIP_MARKET_QUOTES=1

# 1 = само основни екрани (пазар, асистент, регистрация/вход); скрива Абонаменти / Клиенти / Списък.
# VITE_MVP_MODE=1

# Лог на запитвания в .local/leads.jsonl (0 / 1)
AGRI_STORE_LEADS=0

# ─── Имейли: Resend ИЛИ SMTP (ако и двете липсват → контакт/регистрация без имейл, само JSONL при AGRI_STORE_LEADS=1)
# Примерни получатели:
MAIL_TO=info@agrinexus.eu
# Или:
# CONTACT_TO_EMAIL=info@agrinexus.eu

# Resend: https://resend.com — API key от Dashboard; домейнът в MAIL_FROM трябва да е верифициран в Resend (Domains).
RESEND_API_KEY=
# Изходящ адрес: име + имейл от верифициран домейн, напр. AgriNexus <noreply@agrinexus.eu>
MAIL_FROM=

# SMTP алтернатива (ако няма RESEND_API_KEY):
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=AgriNexus <noreply@example.com>

# ─── S3 / Cloudflare R2 (presigned качване) ───
# R2: S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=auto
# Публичен URL на bucket/custom domain (по избор)
S3_PUBLIC_BASE_URL=

# Макс. размер на файл (байтове), подпис TTL
UPLOAD_MAX_BYTES=15728640
UPLOAD_SIGN_TTL_SEC=3600
