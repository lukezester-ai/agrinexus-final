# Копирай като `.env` в корена на проекта и попълни стойностите.
# Файлът `.env` не се качва в Git (.gitignore).

# ─── LLM за чат: OpenAI ИЛИ локален Ollama (данни без облак на машината) ───
# Ако зададеш OLLAMA_BASE_URL, приложението ползва Ollama вместо OpenAI за чат (OpenAI ключ не е нужен).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.35

# Локален Ollama: инсталирай ollama.com → терминал: ollama serve → ollama pull llama3.2
#OLLAMA_BASE_URL=http://127.0.0.1:11434
#OLLAMA_MODEL=llama3.2
# За „Обясни документ“ със снимка нужен vision модел в Ollama:
#OLLAMA_VISION_MODEL=llava

# ─── Локален API (npm run dev — dev-server) ───
DEV_API_PORT=8788

# Пазарни котировки: не задавай | stooq (забавени фючърси) | demo (само синтетика, без външен HTTP)
MARKET_QUOTES_PROVIDER=stooq

# Frontend: 1 = не вика /api/market-quotes (офлайн, синтетика)
# VITE_SKIP_MARKET_QUOTES=1

# 1 = само основни екрани; скрива част от навигацията
# VITE_MVP_MODE=1

# Публичен URL на сайта (PDF/отчети/абсолютни линкове). Локално: http://localhost:5173
VITE_SITE_URL=http://localhost:5173

# Лог на лийдове в .local/leads.jsonl
AGRI_STORE_LEADS=0

# ─── Имейли: Resend ИЛИ SMTP (ако липсват → контакт без изходящ имейл) ───
MAIL_TO=info@agrinexus.eu
# CONTACT_TO_EMAIL=info@agrinexus.eu
# AGRI_INBOX_EMAIL=info@agrinexus.eu

RESEND_API_KEY=
# От: верифициран домейн в Resend
MAIL_FROM=
# RESEND_FROM=  (алтернативно име на поле From)

# SMTP алтернатива:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# MAIL_FROM=AgriNexus <noreply@example.com>

# ─── S3 / Cloudflare R2 (presigned качване) ───
# R2: S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=auto
S3_PUBLIC_BASE_URL=

UPLOAD_MAX_BYTES=15728640
UPLOAD_SIGN_TTL_SEC=3600

# ─── Supabase (облак + Auth) ───
# Публични — влизат във Vite билда:
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Сървър (локален API / Vercel) — същият проект:
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Каталог транспортни фирми (публичен read/insert): изпълни `data/supabase-transport-companies.sql` в Supabase SQL Editor

# ─── Статистика за посещения (по избор; локално обикновено празно) ───
# Локален файл вместо Redis:
# VISIT_STATS_FILE=.local/visit-stats.json
# Upstash Redis (ако ползваш):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# VISIT_STATS_SECRET=  (за защита на write endpoint)

# След промяна на Supabase: рестарт на `npm run dev` или Redeploy.
# Magic link: Supabase → Auth → URL configuration → Site URL + Redirect URLs (localhost + продукция).
