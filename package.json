{
  "name": "agrinexus-pro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsx server/dev-server.ts\"",
    "dev:vite": "vite",
    "dev:api": "tsx server/dev-server.ts",
    "build": "vite build",
    "build:big-heap": "node --max-old-space-size=6144 ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "test:mistral": "tsx scripts/smoke-mistral.ts",
    "test:mistral:vision": "tsx scripts/smoke-mistral-vision.ts",
    "test:rag": "tsx scripts/smoke-rag.ts",
    "ingest:rag": "tsx scripts/ingest-rag.ts",
    "seed:rag": "tsx scripts/seed-rag-known-docs.ts",
    "fetch:docs": "tsx scripts/fetch-and-index-docs.ts",
    "rag:setup": "tsx scripts/rag-setup.ts",
    "rag:setup:json": "tsx scripts/rag-setup-json.ts",
    "test:mail": "tsx scripts/smoke-mail.ts",
    "export:ft:market-watch": "tsx scripts/export-market-watch-ft-jsonl.ts",
    "export:ft:field-watch": "tsx scripts/export-field-learning-jsonl.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.716.0",
    "@aws-sdk/s3-request-presigner": "^3.716.0",
    "@supabase/supabase-js": "^2.105.1",
    "@vercel/node": "^5.0.4",
    "dotenv": "^16.4.7",
    "lucide-react": "0.284.0",
    "nodemailer": "^8.0.7",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "recharts": "2.10.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.1.2",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
