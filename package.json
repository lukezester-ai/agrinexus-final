{
  "name": "sima-pro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsx server/dev-server.ts\"",
    "dev:vite": "vite",
    "dev:api": "tsx server/dev-server.ts",
    "build": "vite build",
    "build:big-heap": "node --max-old-space-size=6144 ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings 0",
    "test": "npm run typecheck && npm run lint:ci && node scripts/verify-no-cloudflare.mjs && npm run build && node scripts/smoke-dev-api.mjs",
    "lint:fix": "eslint . --fix",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "test:mistral": "tsx scripts/smoke-mistral.ts",
    "test:rag": "tsx scripts/smoke-rag.ts",
    "ingest:rag": "tsx scripts/ingest-rag.ts",
    "seed:rag": "tsx scripts/seed-rag-known-docs.ts",
    "fetch:docs": "tsx scripts/fetch-and-index-docs.ts",
    "rag:setup": "tsx scripts/rag-setup.ts",
    "rag:setup:json": "tsx scripts/rag-setup-json.ts",
    "test:mail": "tsx scripts/smoke-mail.ts",
    "export:ft:market-watch": "tsx scripts/export-market-watch-ft-jsonl.ts",
    "export:ft:field-watch": "tsx scripts/export-field-learning-jsonl.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.716.0",
    "@aws-sdk/s3-request-presigner": "^3.716.0",
    "@supabase/supabase-js": "^2.105.1",
    "@vercel/node": "^5.0.4",
    "chart.js": "^4.5.1",
    "dotenv": "^16.4.7",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "leaflet-geosearch": "^4.4.0",
    "lucide-react": "0.284.0",
    "mammoth": "^1.9.1",
    "nodemailer": "^8.0.7",
    "pdf-lib": "^1.17.1",
    "pdf-to-img": "^4.5.0",
    "pdfjs-dist": "^4.10.38",
    "react": "18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "18.2.0",
    "recharts": "2.10.3",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet-draw": "^1.0.13",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.1.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.1.12"
  }
}
