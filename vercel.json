{
  "buildCommand": "NODE_OPTIONS=--max-old-space-size=6144 npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/doc-discovery-cron",
      "schedule": "0 2 * * *"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60,
      "includeFiles": "lib/**"
    }
  }
}
