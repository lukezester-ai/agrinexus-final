{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client", "node"]
  },
  "include": ["*.tsx", "*.ts", "lib/**/*.ts", "api/**/*.ts", "server/**/*.ts"],
  "exclude": ["node_modules", "dist", "App.head.tsx"]
}
