{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client", "node"]
  },
  "include": [
    "*.tsx",
    "*.ts",
    "playwright.config.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "lib/**/*.ts",
    "api/**/*.ts",
    "server/**/*.ts",
    "scripts/**/*.ts",
    "e2e/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
